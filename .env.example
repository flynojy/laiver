PROJECT_NAME=personal-agent-platform
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Local development defaults to SQLite and auto-initializes tables on startup.
# PostgreSQL environments should run `alembic upgrade head` instead of relying on app startup.
DATABASE_URL=sqlite:///./apps/api/local.db
AUTO_INIT_DB=true

POSTGRES_DB=agent_platform
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memories
MEMORY_VECTOR_SIZE=64

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

APP_ENV=development
SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
